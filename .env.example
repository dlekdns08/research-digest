# Anthropic API key — required unless using --dry-run
DIGEST_ANTHROPIC_API_KEY=sk-ant-...

# Path to the arxiv-graph sqlite DB.
# Default: ~/.arxiv-graph/data/arxiv_graph.db
# DIGEST_ARXIV_DB_PATH=/Users/you/.arxiv-graph/data/arxiv_graph.db

# Optional: Slack incoming webhook for --slack delivery
# DIGEST_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Number of top papers to summarize (default 5)
# DIGEST_TOP_N=5

# Claude model to use
# DIGEST_MODEL=claude-sonnet-4-6

# Optional: Voyage AI API key for embedding-based personalization.
# If unset, research-digest falls back to a local hashed TF-IDF.
# DIGEST_VOYAGE_API_KEY=pa-...
# DIGEST_VOYAGE_MODEL=voyage-3

# Optional: state directory for feedback.db / deepread cache.
# Default: ~/.research-digest
# DIGEST_STATE_DIR=/Users/you/.research-digest
